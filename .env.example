# PythonAnywhere: copy this file to .env in the project folder (~/coNFRENCE/.env)
#   cp .env.example .env
#   nano .env   (paste your secret key, save with Ctrl+O, Enter, Ctrl+X)
#
# Generate secret key:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"

DJANGO_SECRET_KEY=replace-with-a-long-random-string
DJANGO_DEBUG=0
DJANGO_ALLOWED_HOSTS=ljietConference7.pythonanywhere.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://ljietConference7.pythonanywhere.com

# Portal link in credential emails
DJANGO_SITE_URL=https://ljietConference7.pythonanywhere.com
DJANGO_SUPPORT_CONTACT_NAME=DHRUV PRAJAPATI
DJANGO_SUPPORT_CONTACT_EMAIL=dhruv.prajapati@ljku.edu.in

# Optional: change default admin password when running create_superadmin
# DJANGO_SUPERADMIN_PASSWORD=your-strong-password

# Email (for Send Email on credentials pages)
# Local dev: emails print in console (default backend)
# PythonAnywhere: use SMTP e.g. Gmail app password
# DJANGO_EMAIL_BACKEND=django.core.mail.backends.smtp.EmailBackend
# DJANGO_EMAIL_HOST=smtp.gmail.com
# DJANGO_EMAIL_PORT=587
# DJANGO_EMAIL_USE_TLS=1
# DJANGO_EMAIL_HOST_USER=your-email@gmail.com
# DJANGO_EMAIL_HOST_PASSWORD=your-app-password
# DJANGO_DEFAULT_FROM_EMAIL=ICRAET 2026 <your-email@gmail.com>

# Optional: paths to bundled Excel files (defaults are in project root)
# FACULTY_DATA_FILE=/home/yourusername/coNFRENCE/fac data.xlsx
# DEFAULT_EVALUATION_TEMPLATE=/home/yourusername/coNFRENCE/EVALUATION FORM (1).xlsx
